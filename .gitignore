# Godot 4+
.godot/
/android/
export_presets.cfg
*.translation

# Python (harness)
__pycache__/
*.pyc
.venv/
venv/

# OS / editor
.DS_Store
Thumbs.db
*.tmp

# Local config / secrets
*.local.json
.env

# Harness scratch (staging is gitignored; builders write only here)
/run/

# Autonomous-mode sentinels (runtime state, never committed)
ops/AUTOPILOT_ON
ops/STOP

# Notifier runtime state (last-emailed commit marker; secret config is *.local.json above)
ops/.notify_state.json

# Remote dashboard access token (generated; never committed)
ops/dashboard_token.local

# Bundled cloudflared binary (downloaded, not source)
ops/bin/

# Persistent autopilot workspace the remote site serves (runtime run data, its own git repo)
/.autopilot/
# Serve-remote console log
ops/serve_remote.log
data/training_all.jsonl
onepond_web.save
ops/gemini_config.local.json
ops/gemini_key.local.txt
assets/art/gemini_*.png
