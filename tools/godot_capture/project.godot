; GGG capture rig — renders an arbitrary scene off-screen and saves a PNG.
; Windows-friendly: NOT --headless (which cannot render); we move the window
; off-screen and capture a fixed-size SubViewport.
config_version=5

[application]
config/name="GGG Capture Rig"
run/main_scene="res://capture.tscn"
config/features=PackedStringArray("4.7", "GL Compatibility")

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
